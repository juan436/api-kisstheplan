# ============================================================
# KissthePlan Backend — Variables de entorno
# ============================================================
# COPIA este archivo a ".env" y completa los valores reales.
# NUNCA hagas commit del archivo .env.
# ============================================================

# --- Servidor ---
PORT=3001

# --- Base de datos ---
MONGODB_URI=mongodb://kisstheplan_user:PASSWORD@kisstheplan-mongodb:27017/kisstheplan?authSource=admin

# --- JWT ---
JWT_SECRET=CAMBIA_ESTE_JWT_SECRET_MUY_LARGO_Y_ALEATORIO
JWT_REFRESH_SECRET=CAMBIA_ESTE_JWT_REFRESH_SECRET_MUY_LARGO
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# --- CORS (URL pública del frontend) ---
CORS_ORIGIN=https://kisstheplan.com

# --- Traefik (dominio público del backend) ---
BACKEND_DOMAIN=api.kisstheplan.com
